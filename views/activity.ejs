<%- include('partials/header') %>

<!-- Page Hero -->
<section class="page-hero page-hero--activity">
  <div class="page-hero__overlay"></div>
  <div class="container page-hero__content">
    <h1 class="page-hero__title">Wildlife Spotter</h1>
    <p class="page-hero__subtitle">Can you identify the hidden animal? Reveal tiles and guess the creature!</p>
  </div>
</section>

<!-- Game Section -->
<section class="section" id="activity-section">
  <div class="container">
    <div class="game-wrapper" id="game-wrapper">

      <!-- Game Instructions -->
      <div class="game-intro" id="game-intro">
        <div class="game-intro__content">
          <h2>How to Play</h2>
          <ol class="game-intro__steps">
            <li>Click tiles to reveal parts of a hidden animal image</li>
            <li>Try to guess which animal is hiding underneath</li>
            <li>The fewer tiles you reveal, the higher your score!</li>
            <li>Select your answer from the choices below the grid</li>
          </ol>
          <p class="game-intro__tip">💡 <strong>Tip:</strong> Start with the corners and edges for clues!</p>
          <button class="btn btn--primary btn--lg" id="start-game">Start Game</button>
        </div>
      </div>

      <!-- Game Area -->
      <div class="game-area" id="game-area" style="display: none;">
        <div class="game-header">
          <div class="game-stats">
            <div class="game-stat">
              <span class="game-stat__label">Tiles Revealed</span>
              <span class="game-stat__value" id="tiles-revealed">0</span>
              <span class="game-stat__total">/ 16</span>
            </div>
            <div class="game-stat">
              <span class="game-stat__label">Score</span>
              <span class="game-stat__value" id="current-score">100</span>
            </div>
            <div class="game-stat">
              <span class="game-stat__label">Best Score</span>
              <span class="game-stat__value" id="best-score">-</span>
            </div>
            <div class="game-stat">
              <span class="game-stat__label">Round</span>
              <span class="game-stat__value" id="current-round">1</span>
              <span class="game-stat__total">/ 5</span>
            </div>
          </div>
        </div>

        <!-- Game Grid -->
        <div class="game-grid-container">
          <div class="game-grid" id="game-grid">
            <!-- 16 tiles (4x4) generated by JS -->
          </div>
          <img class="game-hidden-image" id="game-hidden-image" alt="Hidden animal to guess" src="">
        </div>

        <!-- Answer Choices -->
        <div class="game-choices" id="game-choices">
          <h3 class="game-choices__title">Which animal is it?</h3>
          <div class="game-choices__grid" id="choices-grid">
            <!-- Choices generated by JS -->
          </div>
        </div>

        <!-- Result Message -->
        <div class="game-result" id="game-result" style="display: none;">
          <div class="game-result__content" id="game-result-content">
            <!-- Filled by JS -->
          </div>
        </div>

        <!-- Game Controls -->
        <div class="game-controls">
          <button class="btn btn--secondary" id="next-round" style="display: none;">Next Animal →</button>
          <button class="btn btn--outline" id="restart-game" style="display: none;">Play Again</button>
        </div>
      </div>

      <!-- Game Over -->
      <div class="game-over" id="game-over" style="display: none;">
        <div class="game-over__content">
          <h2>Game Over!</h2>
          <div class="game-over__final-score">
            <span class="game-over__score-label">Final Score</span>
            <span class="game-over__score-value" id="final-score">0</span>
          </div>
          <p class="game-over__message" id="game-over-message"></p>
          <div class="game-over__stats">
            <div class="game-over__stat">
              <span>Correct Answers</span>
              <strong id="correct-answers">0</strong>
            </div>
            <div class="game-over__stat">
              <span>Best Score</span>
              <strong id="final-best-score">0</strong>
            </div>
          </div>
          <button class="btn btn--primary btn--lg" id="play-again">Play Again</button>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Pass animal data to JS -->
<script>
  window.animalData = <%- JSON.stringify(animals.map(function(a) { return { name: a.name, image: a.image, species: a.species }; })) %>;
</script>
<script src="/js/activity.js"></script>

<%- include('partials/footer') %>
