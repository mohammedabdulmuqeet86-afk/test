<%- include('partials/header') %>

<!-- Page Hero -->
<section class="page-hero page-hero--events">
  <div class="page-hero__overlay"></div>
  <div class="container page-hero__content">
    <h1 class="page-hero__title">Events &amp; Special Experiences</h1>
    <p class="page-hero__subtitle">Seasonal festivals, conservation workshops, night safaris, and more.</p>
  </div>
</section>

<!-- Filter Bar -->
<section class="filter-bar" id="event-filters">
  <div class="container">
    <div class="filter-bar__inner">
      <div class="filter-bar__group">
        <label class="filter-bar__label" for="year-filter">Year:</label>
        <select class="filter-select" id="year-filter">
          <option value="all">All Years</option>
          <% years.forEach(function(y) { %>
            <option value="<%= y.year %>" <%= y.year === selectedYear ? 'selected' : '' %>><%= y.year %></option>
          <% }); %>
        </select>
      </div>
      <div class="filter-bar__group">
        <label class="filter-bar__label" for="category-filter">Category:</label>
        <select class="filter-select" id="category-filter">
          <option value="all">All Categories</option>
          <% categories.forEach(function(c) { %>
            <option value="<%= c.category %>"><%= c.category %></option>
          <% }); %>
        </select>
      </div>
      <div class="filter-bar__group">
        <span class="filter-bar__count" id="events-count"><%= events.length %> events found</span>
      </div>
    </div>
  </div>
</section>

<!-- Events Grid -->
<section class="section" id="events-list">
  <div class="container">
    <div class="events-grid events-grid--full" id="events-grid">
      <% events.forEach(function(event) { %>
        <a href="/events/<%= event.slug %>" class="event-card event-card--full" id="event-card-<%= event.id %>">
          <div class="event-card__image-wrapper">
            <img src="<%= event.image %>" alt="<%= event.title %>" class="event-card__image" loading="lazy">
            <span class="event-card__category-badge"><%= event.category %></span>
            <% if (event.is_past) { %>
              <span class="event-card__status-badge event-card__status-badge--past">Past Event</span>
            <% } else { %>
              <span class="event-card__status-badge event-card__status-badge--upcoming">Upcoming</span>
            <% } %>
          </div>
          <div class="event-card__content">
            <div class="event-card__date">
              <span class="event-card__date-day"><%= new Date(event.date).getDate() %></span>
              <span class="event-card__date-month"><%= new Date(event.date).toLocaleString('en-GB', { month: 'short' }) %></span>
              <span class="event-card__date-year"><%= event.year %></span>
            </div>
            <div class="event-card__info">
              <h2 class="event-card__title"><%= event.title %></h2>
              <p class="event-card__desc"><%= event.description %></p>
              <div class="event-card__meta">
                <span class="event-card__time"><%= event.time %></span>
                <span class="event-card__location"><%= event.location %></span>
              </div>
            </div>
          </div>
        </a>
      <% }); %>
    </div>

    <div class="no-results" id="no-results-events" style="display: none;">
      <span class="no-results__icon">No results</span>
      <p>No events match your filters. Try adjusting the year or category.</p>
    </div>
  </div>
</section>

<script src="/js/events.js"></script>
<%- include('partials/footer') %>
