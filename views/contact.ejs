<%- include('partials/header') %>

<!-- Page Hero -->
<section class="page-hero page-hero--contact">
  <div class="page-hero__overlay"></div>
  <div class="container page-hero__content">
    <h1 class="page-hero__title">Contact Us</h1>
    <p class="page-hero__subtitle">We would love to hear from you. Get in touch with our team.</p>
  </div>
</section>

<!-- Contact Section -->
<section class="section" id="contact-section">
  <div class="container">
    <div class="contact-layout">

      <!-- Contact Form -->
      <div class="contact-form-wrapper" id="contact-form-wrapper">
        <h2 class="contact-form__heading">Send Us a Message</h2>
        <p class="contact-form__subtext">Fill in the form below and we will get back to you as soon as possible.</p>

        <form class="contact-form" id="contact-form" novalidate>
          <div class="form-group" id="form-group-name">
            <label class="form-label" for="contact-name">Full Name <span class="required" aria-label="required">*</span></label>
            <input type="text" class="form-input" id="contact-name" name="name" placeholder="Enter your full name" required minlength="2" autocomplete="name">
            <span class="form-error" id="error-name" role="alert"></span>
          </div>

          <div class="form-group" id="form-group-email">
            <label class="form-label" for="contact-email">Email Address <span class="required" aria-label="required">*</span></label>
            <input type="email" class="form-input" id="contact-email" name="email" placeholder="Enter your email address" required autocomplete="email">
            <span class="form-error" id="error-email" role="alert"></span>
          </div>

          <div class="form-group" id="form-group-subject">
            <label class="form-label" for="contact-subject">Subject <span class="required" aria-label="required">*</span></label>
            <input type="text" class="form-input" id="contact-subject" name="subject" placeholder="What is your enquiry about?" required minlength="2">
            <span class="form-error" id="error-subject" role="alert"></span>
          </div>

          <div class="form-group" id="form-group-message">
            <label class="form-label" for="contact-message">Message <span class="required" aria-label="required">*</span></label>
            <textarea class="form-input form-input--textarea" id="contact-message" name="message" placeholder="Tell us more about your enquiry..." required minlength="10" rows="6"></textarea>
            <span class="form-error" id="error-message" role="alert"></span>
          </div>

          <button type="submit" class="btn btn--primary btn--lg btn--full" id="contact-submit">
            <span class="btn__text">Send Message</span>
            <span class="btn__loader" style="display: none;">Sending...</span>
          </button>
        </form>

        <!-- Success Message -->
        <div class="contact-success" id="contact-success" style="display: none;" role="alert">
          <span class="contact-success__icon">&#10003;</span>
          <h3>Message Sent!</h3>
          <p>Thank you for getting in touch. Our team will respond within 48 hours.</p>
          <button class="btn btn--secondary" id="send-another">Send Another Message</button>
        </div>
      </div>

      <!-- Contact Info Sidebar -->
      <aside class="contact-info" id="contact-info">
        <div class="contact-info__card">
          <h3 class="contact-info__title">Visit Us</h3>
          <div class="contact-info__item">
            <div>
              <strong>WildHaven Adventure Park</strong>
              <p>WildHaven Lane, Greenfield<br>GF1 2WP</p>
            </div>
          </div>
        </div>

        <div class="contact-info__card">
          <h3 class="contact-info__title">Opening Times</h3>
          <div class="contact-info__item">
            <div>
              <strong>Open Daily</strong>
              <p>9:00am &ndash; 6:00pm<br>Last Entry: 5:00pm</p>
            </div>
          </div>
        </div>

        <div class="contact-info__card">
          <h3 class="contact-info__title">Get In Touch</h3>
          <div class="contact-info__item">
            <div>
              <strong>Phone</strong>
              <p>01555 012 345</p>
            </div>
          </div>
          <div class="contact-info__item">
            <div>
              <strong>Email</strong>
              <p><a href="mailto:info@wildhaven.example.com">info@wildhaven.example.com</a></p>
            </div>
          </div>
        </div>
      </aside>

    </div>
  </div>
</section>

<script src="/js/contact.js"></script>
<%- include('partials/footer') %>
