<%- include('partials/header') %>

<!-- Event Banner -->
<section class="event-banner" style="background-image: url('<%= event.image %>');">
  <div class="event-banner__overlay"></div>
  <div class="container event-banner__content">
    <% if (event.is_past) { %>
      <span class="event-banner__status event-banner__status--past">This Event Has Ended</span>
    <% } else { %>
      <span class="event-banner__status event-banner__status--upcoming">Upcoming Event</span>
    <% } %>
    <h1 class="event-banner__title"><%= event.title %></h1>
    <div class="event-banner__meta">
      <span class="event-banner__meta-item"><%= new Date(event.date).toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) %></span>
      <span class="event-banner__meta-item"><%= event.time %></span>
      <span class="event-banner__meta-item"><%= event.location %></span>
    </div>
    <span class="event-banner__category"><%= event.category %></span>
  </div>
</section>

<!-- Event Detail -->
<section class="section" id="event-detail">
  <div class="container">
    <div class="event-detail-layout">

      <!-- Main Content -->
      <div class="event-detail__main">
        <% if (event.is_past) { %>
          <div class="event-detail__past-notice" role="alert">
            <span class="event-detail__past-icon">&#9432;</span>
            <div>
              <strong>This event has already taken place.</strong>
              <p>Check out our <a href="/events">Events page</a> for upcoming events and experiences.</p>
            </div>
          </div>
        <% } %>

        <div class="event-detail__description">
          <h2>About This Event</h2>
          <p><%= event.long_description %></p>
        </div>

        <div class="event-detail__image">
          <img src="<%= event.image %>" alt="<%= event.title %>" loading="lazy">
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="event-detail__sidebar">
        <div class="event-detail__info-card">
          <h3>Event Details</h3>
          <ul class="event-detail__info-list">
            <li>
              <span class="event-detail__info-label">Date</span>
              <span class="event-detail__info-value"><%= new Date(event.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) %></span>
            </li>
            <li>
              <span class="event-detail__info-label">Time</span>
              <span class="event-detail__info-value"><%= event.time %></span>
            </li>
            <li>
              <span class="event-detail__info-label">Location</span>
              <span class="event-detail__info-value"><%= event.location %></span>
            </li>
            <li>
              <span class="event-detail__info-label">Category</span>
              <span class="event-detail__info-value"><%= event.category %></span>
            </li>
            <% if (event.habitat_name) { %>
            <li>
              <span class="event-detail__info-label">Habitat</span>
              <span class="event-detail__info-value"><a href="/habitats/<%= event.habitat_slug %>"><%= event.habitat_name %></a></span>
            </li>
            <% } %>
            <li>
              <span class="event-detail__info-label">Status</span>
              <span class="event-detail__info-value">
                <% if (event.is_past) { %>
                  <span class="status-tag status-tag--past">Past</span>
                <% } else { %>
                  <span class="status-tag status-tag--upcoming">Upcoming</span>
                <% } %>
              </span>
            </li>
          </ul>
        </div>

        <div class="event-detail__info-card">
          <h3>Questions?</h3>
          <p>Contact our events team for more information about this and other upcoming events.</p>
          <a href="/contact" class="btn btn--primary btn--full">Get In Touch</a>
        </div>
      </aside>

    </div>
  </div>
</section>

<!-- Related Events -->
<% if (relatedEvents.length > 0) { %>
<section class="section section--alt" id="related-events">
  <div class="container">
    <div class="section-header">
      <span class="section-header__badge">More Events</span>
      <h2 class="section-header__title">You Might Also Like</h2>
    </div>

    <div class="events-grid">
      <% relatedEvents.forEach(function(rel) { %>
        <a href="/events/<%= rel.slug %>" class="event-card">
          <div class="event-card__image-wrapper">
            <img src="<%= rel.image %>" alt="<%= rel.title %>" class="event-card__image" loading="lazy">
            <span class="event-card__category-badge"><%= rel.category %></span>
            <% if (rel.is_past) { %>
              <span class="event-card__status-badge event-card__status-badge--past">Past</span>
            <% } else { %>
              <span class="event-card__status-badge event-card__status-badge--upcoming">Upcoming</span>
            <% } %>
          </div>
          <div class="event-card__content">
            <div class="event-card__date">
              <span class="event-card__date-day"><%= new Date(rel.date).getDate() %></span>
              <span class="event-card__date-month"><%= new Date(rel.date).toLocaleString('en-GB', { month: 'short' }) %></span>
            </div>
            <div class="event-card__info">
              <h3 class="event-card__title"><%= rel.title %></h3>
              <p class="event-card__desc"><%= rel.description.substring(0, 80) %>...</p>
            </div>
          </div>
        </a>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

<!-- Back Link -->
<section class="section section--compact">
  <div class="container" style="text-align: center;">
    <a href="/events" class="btn btn--secondary">← Back to All Events</a>
  </div>
</section>

<%- include('partials/footer') %>
