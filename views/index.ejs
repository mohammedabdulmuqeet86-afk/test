<%- include('partials/header') %>

<!-- Hero Section -->
<section class="hero" id="hero">
  <div class="hero__overlay"></div>
  <div class="hero__content">
    <h1 class="hero__title">
      <span class="hero__title-line">Discover the</span>
      <span class="hero__title-line hero__title-line--highlight">Wild Side</span>
      <span class="hero__title-line">of Adventure</span>
    </h1>
    <p class="hero__subtitle">Explore five immersive habitats, encounter incredible wildlife, and create memories that last a lifetime.</p>
    <div class="hero__cta-group">
      <a href="/habitats" class="btn btn--primary btn--lg">Explore Habitats</a>
      <a href="/events" class="btn btn--outline btn--lg">View Events</a>
    </div>
    <div class="hero__opening-badge">
      <span>Open Daily: <strong>9am &ndash; 6pm</strong></span>
    </div>
  </div>
  <div class="hero__scroll-indicator" aria-hidden="true">
    <span>Scroll to explore</span>
    <div class="hero__scroll-arrow"></div>
  </div>
</section>

<!-- Featured Habitats -->
<section class="section section--habitats" id="featured-habitats">
  <div class="container">
    <div class="section-header">
      <span class="section-header__badge">Our Habitats</span>
      <h2 class="section-header__title">Five Worlds to Explore</h2>
      <p class="section-header__desc">Journey through five incredible ecosystems, each home to fascinating wildlife from around the globe.</p>
    </div>

    <div class="habitat-grid">
      <% habitats.forEach(function(habitat) { %>
        <a href="/habitats/<%= habitat.slug %>" class="habitat-card" id="habitat-card-<%= habitat.id %>">
          <div class="habitat-card__image-wrapper">
            <img src="<%= habitat.image %>" alt="<%= habitat.name %> habitat at WildHaven Adventure Park" class="habitat-card__image" loading="lazy">
            <div class="habitat-card__overlay"></div>
          </div>
          <div class="habitat-card__content">
            <h3 class="habitat-card__title"><%= habitat.name %></h3>
            <p class="habitat-card__tagline"><%= habitat.tagline %></p>
            <span class="habitat-card__climate-badge"><%= habitat.climate %></span>
          </div>
        </a>
      <% }); %>
    </div>

    <div class="section-footer">
      <a href="/habitats" class="btn btn--secondary">View All Habitats</a>
    </div>
  </div>
</section>

<!-- Featured Experiences -->
<section class="section section--experiences" id="featured-experiences">
  <div class="container">
    <div class="section-header">
      <span class="section-header__badge">Experiences</span>
      <h2 class="section-header__title">Unforgettable Encounters</h2>
      <p class="section-header__desc">From feeding giraffes to walking with sharks &mdash; experiences you will never forget.</p>
    </div>

    <div class="exhibit-grid">
      <% exhibits.forEach(function(exhibit) { %>
        <article class="exhibit-card" id="exhibit-card-<%= exhibit.id %>">
          <div class="exhibit-card__image-wrapper">
            <img src="<%= exhibit.image %>" alt="<%= exhibit.name %> experience at WildHaven" class="exhibit-card__image" loading="lazy">
            <span class="exhibit-card__type-badge exhibit-card__type-badge--<%= exhibit.type %>"><%= exhibit.type %></span>
          </div>
          <div class="exhibit-card__content">
            <span class="exhibit-card__habitat"><%= exhibit.habitat_name %></span>
            <h3 class="exhibit-card__title"><%= exhibit.name %></h3>
            <p class="exhibit-card__desc"><%= exhibit.description.substring(0, 120) %>...</p>
            <div class="exhibit-card__meta">
              <% if (exhibit.duration) { %>
                <span class="exhibit-card__meta-item"><%= exhibit.duration %></span>
              <% } %>
              <% if (exhibit.difficulty) { %>
                <span class="exhibit-card__meta-item"><%= exhibit.difficulty %></span>
              <% } %>
            </div>
          </div>
        </article>
      <% }); %>
    </div>

    <div class="section-footer">
      <a href="/exhibits" class="btn btn--secondary">View All Experiences</a>
    </div>
  </div>
</section>

<!-- Upcoming Events -->
<% if (events.length > 0) { %>
<section class="section section--events" id="upcoming-events">
  <div class="container">
    <div class="section-header">
      <span class="section-header__badge">Coming Up</span>
      <h2 class="section-header__title">Upcoming Events</h2>
      <p class="section-header__desc">Special experiences and seasonal celebrations at WildHaven.</p>
    </div>

    <div class="events-grid">
      <% events.forEach(function(event) { %>
        <a href="/events/<%= event.slug %>" class="event-card" id="event-card-<%= event.id %>">
          <div class="event-card__image-wrapper">
            <img src="<%= event.image %>" alt="<%= event.title %>" class="event-card__image" loading="lazy">
            <span class="event-card__category-badge"><%= event.category %></span>
          </div>
          <div class="event-card__content">
            <div class="event-card__date">
              <span class="event-card__date-day"><%= new Date(event.date).getDate() %></span>
              <span class="event-card__date-month"><%= new Date(event.date).toLocaleString('en-GB', { month: 'short' }) %></span>
            </div>
            <div class="event-card__info">
              <h3 class="event-card__title"><%= event.title %></h3>
              <p class="event-card__desc"><%= event.description.substring(0, 100) %>...</p>
              <span class="event-card__time"><%= event.time %></span>
            </div>
          </div>
        </a>
      <% }); %>
    </div>

    <div class="section-footer">
      <a href="/events" class="btn btn--secondary">View All Events</a>
    </div>
  </div>
</section>
<% } %>

<!-- Info Banner -->
<section class="info-banner" id="info-banner">
  <div class="container">
    <div class="info-banner__grid">
      <div class="info-banner__item">
        <h3 class="info-banner__title">5 Habitats</h3>
        <p class="info-banner__desc">From tropical rainforests to frozen Arctic</p>
      </div>
      <div class="info-banner__item">
        <h3 class="info-banner__title">200+ Animals</h3>
        <p class="info-banner__desc">Incredible creatures from around the globe</p>
      </div>
      <div class="info-banner__item">
        <h3 class="info-banner__title">15+ Experiences</h3>
        <p class="info-banner__desc">Adventures for the whole family</p>
      </div>
      <div class="info-banner__item">
        <h3 class="info-banner__title">Open Daily</h3>
        <p class="info-banner__desc">9:00am &ndash; 6:00pm, every day</p>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
