<%- include('partials/header') %>

<!-- Habitat Banner -->
<section class="habitat-banner" style="background-image: url('<%= habitat.banner_image %>');">
  <div class="habitat-banner__overlay"></div>
  <div class="container habitat-banner__content">
    <h1 class="habitat-banner__title"><%= habitat.name %></h1>
    <p class="habitat-banner__tagline"><%= habitat.tagline %></p>
    <span class="habitat-banner__climate"><%= habitat.climate %> Environment</span>
  </div>
</section>

<!-- Habitat Description -->
<section class="section">
  <div class="container">
    <div class="habitat-detail">
      <div class="habitat-detail__text">
        <h2>About This Habitat</h2>
        <p><%= habitat.description %></p>
      </div>
      <div class="habitat-detail__image">
        <img src="<%= habitat.image %>" alt="<%= habitat.name %> at WildHaven" loading="lazy">
      </div>
    </div>
  </div>
</section>

<!-- Animals in this Habitat -->
<% if (animals.length > 0) { %>
<section class="section section--alt" id="habitat-animals">
  <div class="container">
    <div class="section-header">
      <span class="section-header__badge">Wildlife</span>
      <h2 class="section-header__title">Meet the Residents</h2>
      <p class="section-header__desc">The incredible animals that call <%= habitat.name %> home.</p>
    </div>

    <div class="animal-grid">
      <% animals.forEach(function(animal) { %>
        <article class="animal-card" id="animal-<%= animal.id %>">
          <div class="animal-card__image-wrapper">
            <img src="<%= animal.image %>" alt="<%= animal.name %> (<%= animal.species %>)" class="animal-card__image" loading="lazy">
            <% if (animal.conservation_status) { %>
              <span class="animal-card__status animal-card__status--<%= animal.conservation_status.toLowerCase().replace(/\s+/g, '-') %>">
                <%= animal.conservation_status %>
              </span>
            <% } %>
          </div>
          <div class="animal-card__content">
            <h3 class="animal-card__name"><%= animal.name %></h3>
            <span class="animal-card__species"><em><%= animal.species %></em></span>
            <p class="animal-card__desc"><%= animal.description %></p>
          </div>
        </article>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

<!-- Experiences in this Habitat -->
<% if (exhibits.length > 0) { %>
<section class="section" id="habitat-exhibits">
  <div class="container">
    <div class="section-header">
      <span class="section-header__badge">Experiences</span>
      <h2 class="section-header__title">Things to Do</h2>
      <p class="section-header__desc">Interactive experiences and activities in <%= habitat.name %>.</p>
    </div>

    <div class="exhibit-grid">
      <% exhibits.forEach(function(exhibit) { %>
        <article class="exhibit-card" id="exhibit-<%= exhibit.id %>">
          <div class="exhibit-card__image-wrapper">
            <img src="<%= exhibit.image %>" alt="<%= exhibit.name %>" class="exhibit-card__image" loading="lazy">
            <span class="exhibit-card__type-badge exhibit-card__type-badge--<%= exhibit.type %>"><%= exhibit.type %></span>
          </div>
          <div class="exhibit-card__content">
            <h3 class="exhibit-card__title"><%= exhibit.name %></h3>
            <p class="exhibit-card__desc"><%= exhibit.description %></p>
            <div class="exhibit-card__meta">
              <% if (exhibit.duration) { %>
                <span class="exhibit-card__meta-item"><%= exhibit.duration %></span>
              <% } %>
              <% if (exhibit.difficulty) { %>
                <span class="exhibit-card__meta-item"><%= exhibit.difficulty %></span>
              <% } %>
            </div>
          </div>
        </article>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

<!-- Related Events -->
<% if (events.length > 0) { %>
<section class="section section--alt" id="habitat-events">
  <div class="container">
    <div class="section-header">
      <span class="section-header__badge">Events</span>
      <h2 class="section-header__title">Upcoming Events</h2>
    </div>
    <div class="events-grid">
      <% events.forEach(function(event) { %>
        <a href="/events/<%= event.slug %>" class="event-card">
          <div class="event-card__image-wrapper">
            <img src="<%= event.image %>" alt="<%= event.title %>" class="event-card__image" loading="lazy">
            <span class="event-card__category-badge"><%= event.category %></span>
          </div>
          <div class="event-card__content">
            <div class="event-card__date">
              <span class="event-card__date-day"><%= new Date(event.date).getDate() %></span>
              <span class="event-card__date-month"><%= new Date(event.date).toLocaleString('en-GB', { month: 'short' }) %></span>
            </div>
            <div class="event-card__info">
              <h3 class="event-card__title"><%= event.title %></h3>
              <p class="event-card__desc"><%= event.description.substring(0, 80) %>...</p>
            </div>
          </div>
        </a>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

<!-- Back Link -->
<section class="section section--compact">
  <div class="container" style="text-align: center;">
    <a href="/habitats" class="btn btn--secondary">← Back to All Habitats</a>
  </div>
</section>

<%- include('partials/footer') %>
